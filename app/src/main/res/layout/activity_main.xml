<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <!-- ── Topbar ───────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_panel"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BBS grOOve"
            android:textColor="@color/text_pri"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <ImageView
            android:id="@+id/btnPlaylists"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_playlist"
            android:background="@drawable/ripple_circle"
            android:contentDescription="Playlists"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btnOptions"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_settings"
            android:background="@drawable/ripple_circle"
            android:contentDescription="Options"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- ── Barre recherche ──────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_panel"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/urlInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="10dp"
            android:textColor="@color/text_pri"
            android:textColorHint="@color/text_sec"
            android:textSize="14sp"
            android:imeOptions="actionGo"
            android:inputType="text"
            android:maxLines="1"
            android:hint="@string/hint_url" />

        <ImageView
            android:id="@+id/btnLoad"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:padding="10dp"
            android:src="@drawable/ic_play"
            android:background="@drawable/bg_btn"
            android:contentDescription="Charger"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btnImport"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:padding="9dp"
            android:src="@drawable/ic_add"
            android:background="@drawable/bg_btn"
            android:contentDescription="Importer"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- ── Now playing : artwork + métadonnées ──────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="104dp"
            android:layout_height="104dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#000000">

            <ImageView
                android:id="@+id/artwork"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/artwork_placeholder"
                android:scaleType="centerCrop"
                android:contentDescription="Pochette" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/trackTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/text_pri"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/trackArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/trackAlbum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_sec"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_sec"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══ PANNEAU LECTURE ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/playbackPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="File d'attente"
            android:textColor="@color/text_sec"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingVertical="10dp"
            android:paddingHorizontal="16dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/queueList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical"
            android:paddingBottom="8dp" />
    </LinearLayout>

    <!-- ══ PANNEAU PLAYLISTS ════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/playlistsPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="8dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_back"
                android:background="@drawable/ripple_circle"
                android:contentDescription="Retour"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/playlistsTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mes playlists grOOve"
                android:textColor="@color/text_pri"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingStart="8dp" />

            <ImageView
                android:id="@+id/btnNewPlaylist"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_add"
                android:background="@drawable/ripple_circle"
                android:contentDescription="Nouvelle playlist"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/playlistsList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical"
            android:paddingBottom="8dp" />
    </LinearLayout>

    <!-- ══ PLAYER BAR (signature) ═══════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_panel"
        android:paddingHorizontal="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="14dp">

        <!-- Progression -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView android:id="@+id/timeCur"
                android:layout_width="44dp" android:layout_height="wrap_content"
                android:text="0:00" android:textColor="@color/text_sec"
                android:textSize="11sp" />

            <SeekBar android:id="@+id/seekBar"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:max="1000"
                android:progressTint="@color/accent"
                android:thumbTint="@color/accent"
                android:splitTrack="false" />

            <TextView android:id="@+id/timeDur"
                android:layout_width="44dp" android:layout_height="wrap_content"
                android:text="0:00" android:textColor="@color/text_sec"
                android:textSize="11sp" android:gravity="end" />
        </LinearLayout>

        <!-- Contrôles -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <ImageView android:id="@+id/btnShuffle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="44dp" android:padding="11dp"
                android:src="@drawable/ic_shuffle"
                android:background="@drawable/ripple_circle"
                android:contentDescription="Aléatoire"
                android:clickable="true" android:focusable="true" />

            <ImageView android:id="@+id/btnPrev"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="48dp" android:padding="10dp"
                android:src="@drawable/ic_prev"
                android:background="@drawable/ripple_circle"
                android:contentDescription="Précédent"
                android:clickable="true" android:focusable="true" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_weight="1.4"
                android:layout_height="wrap_content"
                android:gravity="center">

                <ImageView android:id="@+id/btnPlay"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:padding="16dp"
                    android:src="@drawable/ic_play"
                    android:background="@drawable/bg_play_circle"
                    android:contentDescription="Lecture / Pause"
                    android:clickable="true" android:focusable="true" />
            </FrameLayout>

            <ImageView android:id="@+id/btnNext"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="48dp" android:padding="10dp"
                android:src="@drawable/ic_next"
                android:background="@drawable/ripple_circle"
                android:contentDescription="Suivant"
                android:clickable="true" android:focusable="true" />

            <ImageView android:id="@+id/btnRepeat"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="44dp" android:padding="11dp"
                android:src="@drawable/ic_repeat"
                android:background="@drawable/ripple_circle"
                android:contentDescription="Répéter"
                android:clickable="true" android:focusable="true" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
