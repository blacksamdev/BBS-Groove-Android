<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="10dp"
    android:paddingHorizontal="16dp"
    android:background="?android:attr/selectableItemBackground">

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="8dp"
        android:src="@drawable/ic_playlist"
        android:contentDescription="Playlist" />

    <LinearLayout
        android:id="@+id/plRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <TextView
            android:id="@+id/plName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_pri"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/plCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_sec"
            android:textSize="12sp"
            android:layout_marginTop="1dp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/plPlay"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:padding="9dp"
        android:src="@drawable/ic_play"
        android:background="@drawable/ripple_circle"
        android:contentDescription="Lire"
        android:clickable="true"
        android:focusable="true" />

    <ImageView
        android:id="@+id/plDelete"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:padding="10dp"
        android:src="@drawable/ic_delete"
        android:background="@drawable/ripple_circle"
        android:contentDescription="Supprimer"
        android:clickable="true"
        android:focusable="true" />
</LinearLayout>
