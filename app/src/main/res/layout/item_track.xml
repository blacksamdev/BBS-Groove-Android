<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Index -->
    <TextView
        android:id="@+id/track_num"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_sec"
        android:textSize="12sp"
        android:gravity="center" />

    <!-- Vignette artwork -->
    <androidx.cardview.widget.CardView
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="4dp"
        app:cardCornerRadius="6dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#000000">

        <ImageView
            android:id="@+id/track_art"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/artwork_placeholder"
            android:scaleType="centerCrop"
            android:contentDescription="Pochette" />
    </androidx.cardview.widget.CardView>

    <!-- Titre + artiste empilés -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/track_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_pri"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/track_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_sec"
            android:textSize="12sp"
            android:layout_marginTop="1dp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Durée -->
    <TextView
        android:id="@+id/track_dur"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textColor="@color/text_sec"
        android:textSize="11sp" />

    <!-- Action + / − -->
    <ImageView
        android:id="@+id/track_action"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="4dp"
        android:padding="9dp"
        android:background="@drawable/ripple_circle"
        android:contentDescription="Action"
        android:clickable="true"
        android:focusable="true" />
</LinearLayout>
